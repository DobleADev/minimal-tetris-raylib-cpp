[Bb]uild-web/
[Bb]uild-desktop/
[Oo]ut/
bin/
lib/

# --- Artefactos de CMake ---
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
Makefile
*.cmake

# Ignore user-specific CMake presets
CMakeUserPresets.json

# --- Archivos de Objetos y Binarios ---
*.o
*.obj
*.so
*.a
*.lib
*.dll
*.exe
*.out
*.app

# --- Dependencias y Paquetes ---
